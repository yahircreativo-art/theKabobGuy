---
import Layout from '../layouts/Layout.astro'
import About from '../layouts/About.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "mainEntityOfPage": "https://thekabobguy.com/about",
  "name": "About The Kabob Guy",
  "url": "https://thekabobguy.com/about",
  "description": "Discover the story behind The Kabob Guy, a Mediterranean-inspired restaurant serving flame-grilled kabobs and bold Persian flavors.",
  "image": "https://thekabobguy.com/favicon.svg",
  "publisher": {
    "@type": "Organization",
    "name": "The Kabob Guy",
    "logo": {
      "@type": "ImageObject",
      "url": "https://thekabobguy.com/favicon.svg"
    }
  }
};
---

<Layout title="The kabob guy" description="The kabob guy | taste of the mediterranean" canonical="/about" schema={schema}>
  <About />
</Layout>
