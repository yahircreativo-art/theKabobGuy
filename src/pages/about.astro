  "@type": "AboutPage",
  "mainEntityOfPage": "#",
  "name": "About",
  "url": "#",
  "description": "Discover the story behind The Kabob Guy, a Mediterranean-inspired restaurant serving flame-grilled kabobs and bold Persian flavors.",
